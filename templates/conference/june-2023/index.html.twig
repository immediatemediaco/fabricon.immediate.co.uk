{% extends 'base-2023.html.twig' %}

{% block title conference.siteTitle %}

{% block body %}
    <nav class="nav">
        <div class="container">
            <div class="nav__logo">
                <img srcset="{{ asset('build/images/fabric-con.png') }} 1x, {{ asset('build/images/fabric-con.png') }} 2x"
                     src="{{ asset('build/images/fabric-con.png') }}"
                     width="210"
                     alt="Logo"
                />
            </div>
        </div>
    </nav>
    <header class="masthead container">
        <picture class="masthead__picture">
            <source media="(max-width: 600px)" srcset="{{ asset('build/images/fabricon-main-square.jpg') }}">
            <source media="(max-width: 1023px)" srcset="{{ asset('build/images/fabricon-main-small.jpg') }}">
            <source media="(min-width: 1024px)" srcset="{{ asset('build/images/fabricon-main.jpg') }}">
            <img alt="Masthead image" src="{{ asset('build/images/fabricon-main.jpg') }}">
        </picture>
        <div class="masthead__heading">
            <h1 class="masthead__title">{{ conference.siteTitle }}</h1>
            <div class="masthead__title-underline"><span></span></div>
        </div>
    </header>
    <main class="conference container">
        <section class="conference__intro">
            <div class="conference__intro-content">
                <h2 class="conference__intro-title">About Fabric Conference</h2>
                <p class="conference__intro-lead">
                    {{ conference.about|striptags }}
                </p>
                {{ settings.conferenceDetails|raw }}
                {% if settings.currentConference is same as(conference) %}
                    {% if conference.slackChannel and conference.slackChannelUrl %}
                        <p>Follow updates throughout the day using <a href="{{ conference.slackChannelUrl }}"
                                                                      target="_blank">{{ conference.slackChannel }}</a>
                            on Slack.</p>
                    {% endif %}
                    <div class="conference__ctas">
                        {{ render(controller('App\\Controller\\QuestionController::new')) }}
                        {% if conference.feedbackFormUrl %}
                            <a href="{{ conference.feedbackFormUrl }}" target="_blank" class="button">Submit
                                feedback</a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
            <div class="conference__intro-img">
                <img src="{{ asset('build/images/bar-area.jpg') }}"
                     alt="Intro image 1">
                <img src="{{ asset('build/images/bar-area-2.jpg') }}"
                     alt="Intro image 2">
            </div>
        </section>
        <section class="schedule">
            <div class="schedule__heading">
                <h2 class="schedule__title">Schedule</h2>
            </div>
            {% if scheduleData.days|length > 1 %}
            <div class="schedule__day-tabs">
                {% for day in scheduleData.days %}
                <button class="schedule__day-tab{% if loop.first %} is-active{% endif %}"
                        data-day="{{ day.dateKey }}"
                        onclick="showScheduleDay('{{ day.dateKey }}', this)">
                    {{ day.date|date('D j M') }}
                </button>
                {% endfor %}
            </div>
            {% endif %}
            {% for day in scheduleData.days %}
            <div class="schedule__day{% if scheduleData.days|length > 1 and not loop.first %} is-hidden{% endif %}"
                 id="day-{{ day.dateKey }}">
                {% if scheduleData.days|length > 1 %}
                <div class="schedule__day-heading">Day {{ loop.index }} — {{ day.dateFormatted }}</div>
                {% endif %}
                <div class="track__heading">
                    <h3 class="track__title">{{ conference.track1Description }}</h3>
                    <h3 class="track__title">{{ conference.track2Description }}</h3>
                </div>
                <div class="schedule__day-grid" style="--day-total-rows: {{ day.totalRows }}">
                    {% for slotData in day.track1Slots %}
                    {% set slot = slotData.slot %}
                    <div class="session session__track--1"
                         style="--grid-row-start: {{ slotData.gridRowStart }}; --grid-row-end: {{ slotData.gridRowEnd }}">
                        <div class="session__heading">
                            <div class="session__people">{{ slot.talk.speakers|join(', ') }}</div>
                            <div class="session__time">
                                {{ slot.startTime|date('H:i') }}-{{ slot.endTime|date('H:i') }}
                            </div>
                        </div>
                        <h5 class="session__title">{{- slot.talk.title -}}</h5>
                        <div class="session__location">{{ conference.track1Description }}</div>
                        <div class="session__content">
                            {% if slot.talk.description %}
                                {{ slot.talk.description | raw }}
                            {% endif %}
                        </div>
                        <div class="session__footer">
                        {% if slot.talk.moderator %}
                            Moderated by {{ slot.talk.moderator }}
                        {% endif %}
                        {% if slot.talk.slackChannelUrl and slot.talk.slackChannel %}
                            <a href="{{ slot.talk.slackChannelUrl }}" class="session__link" target="_blank"><i
                                        class="talk__icon icon icon--slack"></i>{{ slot.talk.slackChannel }}</a>
                        {% elseif slot.talk.slackChannel %}
                            <p class="session__link"><i class="talk__icon icon icon--slack"></i>{{ slot.talk.slackChannel }}</p>
                        {% endif %}
                        {% if slot.talk.teamsUrl %}
                            <a href="{{ slot.talk.teamsUrl }}" class="session__link" target="_blank"><i class="talk__icon icon icon--teams"></i>Join on Microsoft
                                Teams</a>
                        {% endif %}
                        {% if slot.talk.slidoUrl %}
                            <a href="{{ slot.talk.slidoUrl }}" class="session__link" target="_blank"><i
                                        class="talk__icon icon icon--slido"></i>{{ slot.talk.slidoText ?: slot.talk.slidoUrl }}</a>
                        {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                    {% for slotData in day.track2Slots %}
                    {% set slot = slotData.slot %}
                    <div class="session session__track--2"
                         style="--grid-row-start: {{ slotData.gridRowStart }}; --grid-row-end: {{ slotData.gridRowEnd }}">
                        <div class="session__heading">
                            <div class="session__people">{{ slot.talk.speakers|join(', ') }}</div>
                            <div class="session__time">
                                {{ slot.startTime|date('H:i') }}-{{ slot.endTime|date('H:i') }}
                            </div>
                        </div>
                        <h5 class="session__title">{{- slot.talk.title -}}</h5>
                        <div class="session__location">{{ conference.track2Description }}</div>
                        <div class="session__content">
                            {% if slot.talk.description %}
                                {{ slot.talk.description | raw }}
                            {% endif %}
                        </div>
                        <div class="session__footer">
                        {% if slot.talk.moderator %}
                            Moderated by {{ slot.talk.moderator }}
                        {% endif %}
                        {% if slot.talk.slackChannelUrl and slot.talk.slackChannel %}
                            <a href="{{ slot.talk.slackChannelUrl }}" class="session__link" target="_blank"><i
                                        class="talk__icon icon icon--slack"></i>{{ slot.talk.slackChannel }}</a>
                        {% elseif slot.talk.slackChannel %}
                            <p class="session__link"><i class="talk__icon icon icon--slack"></i>{{ slot.talk.slackChannel }}</p>
                        {% endif %}
                        {% if slot.talk.teamsUrl %}
                            <a href="{{ slot.talk.teamsUrl }}" class="session__link" target="_blank"><i class="talk__icon icon icon--teams"></i>Join on Microsoft
                                Teams</a>
                        {% endif %}
                        {% if slot.talk.slidoUrl %}
                            <a href="{{ slot.talk.slidoUrl }}" class="session__link" target="_blank"><i
                                        class="talk__icon icon icon--slido"></i>{{ slot.talk.slidoText ?: slot.talk.slidoUrl }}</a>
                        {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                    {% for slotData in day.breaks %}
                    {% set slot = slotData.slot %}
                    <div class="schedule__break"
                         style="--grid-row-start: {{ slotData.gridRowStart }}; --grid-row-end: {{ slotData.gridRowEnd }}">
                        <h4 class="schedule__break-text">{{ slot.breakDetails }}</h4>
                        <p class="schedule__break-time">
                            {{ slot.startTime|date('H:i') }}-{{ slot.endTime|date('H:i') }}
                        </p>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </section>
    </main>
    <footer class="footer">
        <img class="footer__logo" src="{{ asset('build/images/im-logo.png') }}" alt="Immediate Media" width="150"
             height="60" loading="lazy">
        <p class="footer__copy">&copy; 2020-{{ "now"|date("Y") }} Copyright Immediate Media Co.</p>
    </footer>
    {% if scheduleData.days|length > 1 %}
    <script>
    function showScheduleDay(dateKey, btn) {
        document.querySelectorAll('.schedule__day').forEach(function(el) { el.classList.add('is-hidden'); });
        document.querySelectorAll('.schedule__day-tab').forEach(function(el) { el.classList.remove('is-active'); });
        document.getElementById('day-' + dateKey).classList.remove('is-hidden');
        btn.classList.add('is-active');
    }
    </script>
    {% endif %}
{% endblock %}
